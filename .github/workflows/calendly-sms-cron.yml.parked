name: Calendly SMS Reminders (parked)

on:
  workflow_dispatch:

jobs:
  send-reminders:
    if: ${{ false }}
    runs-on: ubuntu-latest
    steps:
      - name: Trigger Calendly SMS reminder cron endpoint
        run: |
          curl --fail --show-error --silent \
            -X POST "https://concilio-2.vercel.app/api/cron/calendly-sms-reminders" \
            -H "x-cron-secret: ${{ secrets.CRON_SHARED_SECRET }}" \
            -H "Content-Type: application/json" \
            -d '{}'
