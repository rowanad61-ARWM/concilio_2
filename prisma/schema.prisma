enum TaskStatus {
  NOT_STARTED
  IN_PROGRESS
  WAITING_EXTERNAL
  WAITING_INTERNAL
  NEEDS_REVIEW
  WITH_CLIENT
  STUCK
  ON_HOLD
  DONE
  CANCELLED
}

enum RecurrenceCadence {
  WEEKLY
  MONTHLY
  QUARTERLY
  HALF_YEARLY
  YEARLY
}

model Task {
  id                    String                  @id @default(cuid())
  clientId              String                  @db.Uuid
  title                 String
  description           String?                 @db.Text
  type                  String
  subtype               String?
  status                TaskStatus              @default(NOT_STARTED)
  dueDateStart          DateTime?
  dueDateEnd            DateTime?
  completedAt           DateTime?
  isRecurring           Boolean                 @default(false)
  recurrenceCadence     RecurrenceCadence?
  recurrenceEndDate     DateTime?
  recurrenceCount       Int?
  mondayItemId          String?
  mondayLastSyncAt      DateTime?
  parentTaskId          String?
  parent                Task?                   @relation("TaskRecurrence", fields: [parentTaskId], references: [id])
  children              Task[]                  @relation("TaskRecurrence")
  owners                TaskOwner[]
  documentLinks         TaskDocumentLink[]
  notes                 TaskNote[]
  workflow_spawned_task workflow_spawned_task[]
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt

  @@index([clientId])
  @@index([status])
  @@index([parentTaskId])
}

enum TaskNoteSource {
  CONCILIO
  MONDAY
  SYSTEM
}

model TaskNote {
  id        String         @id @default(cuid())
  taskId    String
